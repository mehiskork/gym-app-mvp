package com.gymapp.backend.repository;

import com.gymapp.backend.model.SyncDelta;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.test.context.DynamicPropertyRegistry;
import org.springframework.test.context.DynamicPropertySource;
import org.testcontainers.containers.PostgreSQLContainer;
import org.testcontainers.junit.jupiter.Container;
import org.testcontainers.junit.jupiter.Testcontainers;

import java.sql.Timestamp;
import java.time.Instant;
import java.util.List;
import java.util.Map;

import static org.assertj.core.api.Assertions.assertThat;

/**
 * Integration tests for SyncRepository using real PostgreSQL via Testcontainers
 * These tests verify database-level correctness (constraints, indexes,
 * ordering)
 */
@SpringBootTest
@Testcontainers
class SyncRepositoryIT {

    @Container
    static PostgreSQLContainer<?> postgres = new PostgreSQLContainer<>("postgres:15")
            .withDatabaseName("testdb")
            .withUsername("test")
            .withPassword("test");

    @DynamicPropertySource
    static void configureProperties(DynamicPropertyRegistry registry) {
        registry.add("spring.datasource.url", postgres::getJdbcUrl);
        registry.add("spring.datasource.username", postgres::getUsername);
        registry.add("spring.datasource.password", postgres::getPassword);
        registry.add("spring.flyway.enabled", () -> "true");
    }

    @Autowired
    private SyncRepository syncRepository;

    @Autowired
    private JdbcTemplate jdbcTemplate;

    private String testGuestUserId;

    @BeforeEach
    void setUp() {
        testGuestUserId = "guest-" + System.currentTimeMillis();
    }

    @Test
    void insertOpLedgerIfAbsent_isIdempotent() {
        // Arrange
        String opId = "op-" + System.currentTimeMillis();
        Instant receivedAt = Instant.now();

        // Act
        boolean first = syncRepository.insertOpLedgerIfAbsent(opId, "device-1", testGuestUserId, receivedAt);
        boolean second = syncRepository.insertOpLedgerIfAbsent(opId, "device-1", testGuestUserId, receivedAt);

        // Assert
        assertThat(first).isTrue();
        assertThat(second).isFalse();
    }

    @Test
    void fetchDeltas_shouldRespectCursorAndLimit() {
        // Arrange: Insert 5 changes
        for (int i = 1; i <= 5; i++) {
            syncRepository.insertChangeLog(
                    testGuestUserId,
                    "workout",
                    "workout-" + i,
                    "upsert",
                    Map.of("name", "Exercise " + i));
        }

        // Act: Fetch first 3
        List<SyncDelta> batch1 = syncRepository.fetchDeltas(testGuestUserId, 0L, 3, List.of("workout"));

        // Assert batch 1
        assertThat(batch1).hasSize(3);
        assertThat(batch1.get(0).entityId()).isEqualTo("workout-1");
        assertThat(batch1.get(2).entityId()).isEqualTo("workout-3");

        // Act: Fetch next 2 using cursor
        long cursor = batch1.get(2).changeId();
        List<SyncDelta> batch2 = syncRepository.fetchDeltas(testGuestUserId, cursor, 3, List.of("workout"));

        // Assert batch 2
        assertThat(batch2).hasSize(2);
        assertThat(batch2.get(0).entityId()).isEqualTo("workout-4");
        assertThat(batch2.get(1).entityId()).isEqualTo("workout-5");
    }

    @Test
    void fetchMaxChangeId_shouldFilterByEntityType() {
        // Arrange: Insert mixed entity types
        syncRepository.insertChangeLog(testGuestUserId, "workout", "w-1", "upsert", Map.of("id", "w-1"));
        long change1 = getLastChangeId();

        syncRepository.insertChangeLog(testGuestUserId, "exercise", "e-1", "upsert", Map.of("id", "e-1"));
        long change2 = getLastChangeId();

        syncRepository.insertChangeLog(testGuestUserId, "workout", "w-2", "upsert", Map.of("id", "w-2"));
        long change3 = getLastChangeId();

        // Act: Fetch cursor filtering only "workout" type
        long cursorWorkoutOnly = syncRepository.fetchMaxChangeId(
                testGuestUserId,
                0L,
                2,
                List.of("workout"));

        // Assert: Should return change1 (first workout), not change2 (which is
        // exercise)
        assertThat(cursorWorkoutOnly).isEqualTo(change1);

        // Act: Fetch cursor with both types
        long cursorBothTypes = syncRepository.fetchMaxChangeId(
                testGuestUserId,
                0L,
                2,
                List.of("workout", "exercise"));

        // Assert: Should return change2 (second in order)
        assertThat(cursorBothTypes).isEqualTo(change2);
    }

    @Test
    void upsertEntityState_shouldUseProvidedTimestamp() {
        // Arrange
        Instant fixedTime = Instant.parse("2025-01-28T12:00:00Z");

        // Act: Insert with fixed timestamp
        syncRepository.upsertEntityState(
                testGuestUserId,
                "workout",
                "w-1",
                Map.of("name", "Deadlift"),
                fixedTime);

        // Wait to ensure DB time would be different if using now()
        try {
            Thread.sleep(1000);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }

        // Act: Update with same fixed timestamp
        syncRepository.upsertEntityState(
                testGuestUserId,
                "workout",
                "w-1",
                Map.of("name", "Deadlift Updated"),
                fixedTime);

        // Assert: Verify both timestamps are still fixedTime (not DB now())
        var result = jdbcTemplate.queryForMap(
                "SELECT updated_at, last_received_at FROM entity_state WHERE guest_user_id = ? AND entity_id = ?",
                testGuestUserId, "w-1");

        Instant updatedAt = ((Timestamp) result.get("updated_at")).toInstant();
        Instant lastReceivedAt = ((Timestamp) result.get("last_received_at")).toInstant();

        assertThat(updatedAt).isEqualTo(fixedTime);
        assertThat(lastReceivedAt).isEqualTo(fixedTime);
    }

    @Test
    void changeLog_shouldMaintainInsertionOrder() {
        // Arrange: Insert 100 changes rapidly
        for (int i = 1; i <= 100; i++) {
            syncRepository.insertChangeLog(
                    testGuestUserId,
                    "workout",
                    "w-" + i,
                    "upsert",
                    Map.of("sequence", i));
        }

        // Act: Fetch all changes
        List<SyncDelta> deltas = syncRepository.fetchDeltas(
                testGuestUserId,
                0L,
                100,
                List.of("workout"));

        // Assert: change_id should be strictly increasing
        for (int i = 1; i < deltas.size(); i++) {
            assertThat(deltas.get(i).changeId()).isGreaterThan(deltas.get(i - 1).changeId());
        }
    }

    @Test
    void fetchDeltas_withNoCursor_shouldStartFromBeginning() {
        // Arrange
        syncRepository.insertChangeLog(testGuestUserId, "workout", "w-1", "upsert", Map.of());
        syncRepository.insertChangeLog(testGuestUserId, "workout", "w-2", "upsert", Map.of());

        // Act
        List<SyncDelta> deltas = syncRepository.fetchDeltas(testGuestUserId, 0L, 10, List.of("workout"));

        // Assert
        assertThat(deltas).hasSize(2);
        assertThat(deltas.get(0).entityId()).isEqualTo("w-1");
        assertThat(deltas.get(1).entityId()).isEqualTo("w-2");
    }

    @Test
    void fetchDeltas_withHighCursor_shouldReturnEmpty() {
        // Arrange
        syncRepository.insertChangeLog(testGuestUserId, "workout", "w-1", "upsert", Map.of());
        long lastChangeId = getLastChangeId();

        // Act: Query with cursor beyond last change
        List<SyncDelta> deltas = syncRepository.fetchDeltas(
                testGuestUserId,
                lastChangeId + 1000,
                10,
                List.of("workout"));

        // Assert
        assertThat(deltas).isEmpty();
    }

    @Test
    void upsertEntityState_shouldPreserveDeletedAt() {
        // Arrange: Insert entity with deleted_at
        Instant now = Instant.now();
        Map<String, Object> deletedPayload = Map.of(
                "id", "w-1",
                "name", "Deleted Workout",
                "deleted_at", now.toString());

        syncRepository.upsertEntityState(testGuestUserId, "workout", "w-1", deletedPayload, now);

        // Act: Try to update (should preserve deleted state)
        Map<String, Object> updatePayload = Map.of(
                "id", "w-1",
                "name", "Updated Name",
                "deleted_at", now.toString());
        syncRepository.upsertEntityState(testGuestUserId, "workout", "w-1", updatePayload, now);

        // Assert
        var result = syncRepository.findEntityState(testGuestUserId, "workout", "w-1");
        assertThat(result).isPresent();
        assertThat(result.get().get("deleted_at")).isNotNull();
    }

    private long getLastChangeId() {
        Long changeId = jdbcTemplate.queryForObject(
                "SELECT MAX(change_id) FROM change_log WHERE guest_user_id = ?",
                Long.class,
                testGuestUserId);
        return changeId != null ? changeId : 0L;
    }
}